   "source": [
    "## 11. Attention Heatmaps — Interpreting Predictions\n",
    "\n",
    "We use the `bilstm_explain_model` (same weights as `bilstm_model`, but also returns attention weights) to see **which words the model focused on** for a given prediction."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "14b74095",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-22T00:08:36.119529Z",
     "iopub.status.busy": "2026-07-22T00:08:36.119264Z",
     "iopub.status.idle": "2026-07-22T00:08:36.130326Z",
     "shell.execute_reply": "2026-07-22T00:08:36.129298Z"
    }
   },
   "outputs": [],
   "source": [
    "from IPython.display import display, HTML\n",
    "\n",
    "def get_attention(text, max_len=MAX_LEN):\n",
    "    clean = clean_text(text)\n",
    "    seq = tokenizer.texts_to_sequences([clean])\n",
    "    padded = tf.keras.preprocessing.sequence.pad_sequences(seq, maxlen=max_len, padding=\"post\", truncating=\"post\")\n",
    "    probs, attn = bilstm_explain_model.predict(padded, verbose=0)\n",
    "    tokens = clean.split()[:max_len]\n",
    "    weights = attn[0, :len(tokens), 0]\n",
    "    weights = weights / (weights.sum() + 1e-9)\n",
    "    pred_idx = int(np.argmax(probs[0]))\n",
    "    return tokens, weights, le.classes_[pred_idx], probs[0]\n",
    "\n",
    "def plot_attention_heatmap(text):\n",
    "    tokens, weights, pred_label, probs = get_attention(text)\n",
    "    fig, ax = plt.subplots(figsize=(max(6, len(tokens) * 0.65), 2.4))\n",
    "    norm_w = weights / (weights.max() + 1e-9)\n",
    "    colors = plt.cm.YlOrRd(0.25 + 0.65 * norm_w)\n",
    "    ax.bar(range(len(tokens)), weights, color=colors)\n",
    "    ax.set_xticks(range(len(tokens)))\n",
    "    ax.set_xticklabels(tokens, rotation=40, ha=\"right\")\n",
    "    ax.set_ylabel(\"Attention weight\")\n",
    "    emoji = EMOTION_EMOJI.get(pred_label, \"\")\n",
    "    ax.set_title(f'Predicted: {pred_label.upper()} {emoji}   (confidence {probs.max()*100:.1f}%)')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "def display_attention_html(text):\n",
    "    tokens, weights, pred_label, probs = get_attention(text)\n",
    "    norm_w = weights / (weights.max() + 1e-9)\n",
    "    spans = []\n",
    "    color = EMOTION_COLORS.get(pred_label, \"#4C5FD5\")\n",
    "    for tok, w in zip(tokens, norm_w):\n",
    "        alpha = 0.12 + 0.75 * w\n",
    "        spans.append(\n",
    "            f'<span style=\"background-color:{color}{int(alpha*255):02x}; padding:3px 6px; '\n",
    "            f'margin:2px; border-radius:6px; display:inline-block;\">{tok}</span>'\n",
    "        )\n",
    "    html = (f'<div style=\"font-family:Inter,sans-serif; font-size:16px; line-height:2.2;\">{\" \".join(spans)}</div>'\n",
    "            f'<p style=\"font-family:Inter,sans-serif;\">Predicted emotion: '\n",
    "            f'<b style=\"color:{color}\">{pred_label} {EMOTION_EMOJI.get(pred_label,\"\")}</b> '\n",
    "            f'({probs.max()*100:.1f}% confidence)</p>')\n",
    "    display(HTML(html))\n"
   ]
  },
