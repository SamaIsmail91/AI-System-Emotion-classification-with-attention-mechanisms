    "EMBED_DIM = 100\n",
    "embedding_matrix = np.random.normal(0, 0.1, (VOCAB_SIZE_ACTUAL, EMBED_DIM)).astype(\"float32\")\n",
    "embedding_matrix[0] = np.zeros(EMBED_DIM)  # padding token\n",
    "\n",
    "glove_hits = 0\n",
    "try:\n",
    "    import gensim.downloader as gensim_api\n",
    "    print(\"Downloading / loading glove-wiki-gigaword-100 (first run may take a minute)...\")\n",
    "    glove = gensim_api.load(\"glove-wiki-gigaword-100\")\n",
    "    for word, idx in tokenizer.word_index.items():\n",
    "        if idx >= VOCAB_SIZE_ACTUAL:\n",
    "            continue\n",
    "        if word in glove:\n",
    "            embedding_matrix[idx] = glove[word]\n",
    "            glove_hits += 1\n",
    "    print(f\"GloVe coverage: {glove_hits}/{VOCAB_SIZE_ACTUAL-1} vocab words found \"\n",
    "          f\"({glove_hits/(VOCAB_SIZE_ACTUAL-1)*100:.1f}%)\")\n",
    "    del glove\n",
    "except Exception as e:\n",
    "    print(f\"Could not load GloVe in this environment ({type(e).__name__}: {e}).\")\n",
    "    print(\"Falling back to random-initialized embeddings (the model will still train, just from scratch).\")\n",
    "\n",
    "print(\"Embedding matrix shape:\", embedding_matrix.shape)\n"
   ]
