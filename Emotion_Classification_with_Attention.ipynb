   "source": [
    "RNN_UNITS = 64\n",
    "ATTN_UNITS = 32\n",
    "DENSE_UNITS = 32\n",
    "DROPOUT = 0.3\n",
    "\n",
    "def build_lstm(vocab_size, embed_dim, embedding_matrix, max_len, num_classes):\n",
    "    inputs = tf.keras.Input(shape=(max_len,), name=\"input_ids\")\n",
    "    x = tf.keras.layers.Embedding(vocab_size, embed_dim, weights=[embedding_matrix],\n",
    "                                   trainable=False, mask_zero=True, name=\"embedding\")(inputs)\n",
    "    x = tf.keras.layers.LSTM(RNN_UNITS, name=\"lstm\")(x)\n",
    "    x = tf.keras.layers.Dense(DENSE_UNITS, activation=\"relu\")(x)\n",
    "    x = tf.keras.layers.Dropout(DROPOUT)(x)\n",
    "    outputs = tf.keras.layers.Dense(num_classes, activation=\"softmax\", name=\"predictions\")(x)\n",
    "    return tf.keras.Model(inputs, outputs, name=\"LSTM_baseline\")\n",
    "\n",
    "def build_gru(vocab_size, embed_dim, embedding_matrix, max_len, num_classes):\n",
    "    inputs = tf.keras.Input(shape=(max_len,), name=\"input_ids\")\n",
    "    x = tf.keras.layers.Embedding(vocab_size, embed_dim, weights=[embedding_matrix],\n",
    "                                   trainable=False, mask_zero=True, name=\"embedding\")(inputs)\n",
    "    x = tf.keras.layers.GRU(RNN_UNITS, name=\"gru\")(x)\n",
    "    x = tf.keras.layers.Dense(DENSE_UNITS, activation=\"relu\")(x)\n",
    "    x = tf.keras.layers.Dropout(DROPOUT)(x)\n",
    "    outputs = tf.keras.layers.Dense(num_classes, activation=\"softmax\", name=\"predictions\")(x)\n",
    "    return tf.keras.Model(inputs, outputs, name=\"GRU_baseline\")\n",
    "\n",
    "def build_bilstm_attention(vocab_size, embed_dim, embedding_matrix, max_len, num_classes):\n",
    "    inputs = tf.keras.Input(shape=(max_len,), name=\"input_ids\")\n",
    "    x = tf.keras.layers.Embedding(vocab_size, embed_dim, weights=[embedding_matrix],\n",
    "                                   trainable=False, mask_zero=True, name=\"embedding\")(inputs)\n",
    "    x = tf.keras.layers.Bidirectional(tf.keras.layers.LSTM(RNN_UNITS, return_sequences=True), name=\"bilstm\")(x)\n",
    "    context_vector, attn_weights = AttentionLayer(ATTN_UNITS, name=\"attention\")(x)\n",
    "    x = tf.keras.layers.Dense(DENSE_UNITS, activation=\"relu\")(context_vector)\n",
    "    x = tf.keras.layers.Dropout(DROPOUT)(x)\n",
    "    outputs = tf.keras.layers.Dense(num_classes, activation=\"softmax\", name=\"predictions\")(x)\n",
    "    clf_model = tf.keras.Model(inputs, outputs, name=\"BiLSTM_Attention\")\n",
    "    explain_model = tf.keras.Model(inputs, [outputs, attn_weights], name=\"BiLSTM_Attention_Explainer\")\n",
    "    return clf_model, explain_model\n",
    "\n",
    "lstm_model = build_lstm(VOCAB_SIZE_ACTUAL, EMBED_DIM, embedding_matrix, MAX_LEN, NUM_CLASSES)\n",
    "gru_model  = build_gru(VOCAB_SIZE_ACTUAL, EMBED_DIM, embedding_matrix, MAX_LEN, NUM_CLASSES)\n",
    "bilstm_model, bilstm_explain_model = build_bilstm_attention(VOCAB_SIZE_ACTUAL, EMBED_DIM, embedding_matrix, MAX_LEN, NUM_CLASSES)\n",
    "\n",
    "for m in (lstm_model, gru_model, bilstm_model):\n",
    "    m.compile(optimizer=tf.keras.optimizers.Adam(1e-3),\n",
    "              loss=\"sparse_categorical_crossentropy\", metrics=[\"accuracy\"])\n",
    "\n",
    "bilstm_model.summary()\n"
   ]
  },
