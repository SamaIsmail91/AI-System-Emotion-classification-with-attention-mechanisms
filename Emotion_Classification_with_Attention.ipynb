   "source": [
    "## 7. Custom Attention Layer\n",
    "\n",
    "A standard **additive (Bahdanau-style) attention-pooling** layer: it learns a score for every BiLSTM hidden state, turns the scores into a probability distribution over the sequence with softmax, and pools the hidden states into a single context vector as their weighted sum. Padded timesteps are masked out (set to $-\\infty$ before the softmax) so they never receive attention weight.\n",
    "\n",
    "The layer returns **both** the context vector (used for classification) and the attention weights (used later for the heatmap visualization)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "2e523a28",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-22T00:00:38.959721Z",
     "iopub.status.busy": "2026-07-22T00:00:38.959155Z",
     "iopub.status.idle": "2026-07-22T00:00:38.967150Z",
     "shell.execute_reply": "2026-07-22T00:00:38.966298Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "AttentionLayer defined.\n"
     ]
    }
   ],
   "source": [
    "@tf.keras.utils.register_keras_serializable(package=\"custom\")\n",
    "class AttentionLayer(tf.keras.layers.Layer):\n",
    "    def __init__(self, units, **kwargs):\n",
    "        super().__init__(**kwargs)\n",
    "        self.units = units\n",
    "        self.W = tf.keras.layers.Dense(units)\n",
    "        self.V = tf.keras.layers.Dense(1)\n",
    "        self.supports_masking = True\n",
    "\n",
    "    def call(self, hidden_states, mask=None):\n",
    "        score = self.V(tf.nn.tanh(self.W(hidden_states)))          # (batch, time, 1)\n",
    "        if mask is not None:\n",
    "            mask = tf.cast(mask, score.dtype)\n",
    "            mask = tf.expand_dims(mask, axis=-1)                    # (batch, time, 1)\n",
    "            score += (1.0 - mask) * -1e9\n",
    "        attention_weights = tf.nn.softmax(score, axis=1)            # (batch, time, 1)\n",
    "        context_vector = tf.reduce_sum(attention_weights * hidden_states, axis=1)  # (batch, features)\n",
    "        return context_vector, attention_weights\n",
    "\n",
    "    def compute_mask(self, inputs, mask=None):\n",
    "        # context_vector has no time axis; stop mask propagation to downstream layers.\n",
    "        return None, None\n",
    "\n",
    "    def get_config(self):\n",
    "        config = super().get_config()\n",
    "        config.update({\"units\": self.units})\n",
    "        return config\n",
    "\n",
    "print(\"AttentionLayer defined.\")\n"
   ]
  },
