   "source": [
    "## 12. Fine-Tuning DistilBERT (HuggingFace `Trainer`)\n",
    "\n",
    "Finally, I fine-tune `distilbert-base-uncased` on the same train/val/test split using the HuggingFace `Trainer` API, and compare it against the three custom models above.\n",
    "\n",
    "> This section needs internet access to `huggingface.co` (to download the pretrained weights) and benefits a lot from a GPU. It is wrapped in a `try/except` so the rest of the notebook still runs cleanly in restricted/offline environments — if it can't reach the Hub here, it prints a short message and moves on. Just re-run this cell in an environment with internet access (Colab, Kaggle, or your own machine) to get real DistilBERT numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 28,
   "id": "daf2f053",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-22T00:08:38.328204Z",
     "iopub.status.busy": "2026-07-22T00:08:38.327911Z",
     "iopub.status.idle": "2026-07-22T00:08:38.338363Z",
     "shell.execute_reply": "2026-07-22T00:08:38.337542Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[Skipping DistilBERT fine-tuning here] ModuleNotFoundError: No module named 'transformers'\n",
      "This cell is fully functional in an environment with internet access to huggingface.co\n",
      "(e.g. Google Colab, Kaggle, or a local machine with a GPU). Re-run it there for real results.\n"
     ]
    }
   ],
   "source": [
    "RUN_TRANSFORMER = True   # set to False to skip this section entirely\n",
    "TRANSFORMER_EPOCHS = 3\n",
    "TRANSFORMER_MODEL_NAME = \"distilbert-base-uncased\"\n",
    "\n",
    "if RUN_TRANSFORMER:\n",
    "    try:\n",
    "        from transformers import (DistilBertTokenizerFast, DistilBertForSequenceClassification,\n",
    "                                   TrainingArguments, Trainer, DataCollatorWithPadding)\n",
    "        from datasets import Dataset\n",
    "\n",
    "        bert_tokenizer = DistilBertTokenizerFast.from_pretrained(TRANSFORMER_MODEL_NAME)\n",
    "\n",
    "        def to_hf_dataset(df):\n",
    "            frame = pd.DataFrame({\n",
    "                \"text\": df[\"clean_text\"].tolist(),\n",
    "                \"label\": le.transform(df[\"emotion\"]).tolist(),\n",
    "            })\n",
    "            return Dataset.from_pandas(frame, preserve_index=False)\n",
    "\n",
    "        train_ds = to_hf_dataset(train_df)\n",
    "        val_ds = to_hf_dataset(val_df)\n",
    "        test_ds = to_hf_dataset(test_df)\n",
    "\n",
    "        def tokenize_fn(batch):\n",
    "            return bert_tokenizer(batch[\"text\"], truncation=True, max_length=MAX_LEN)\n",
    "\n",
    "        train_ds = train_ds.map(tokenize_fn, batched=True)\n",
    "        val_ds = val_ds.map(tokenize_fn, batched=True)\n",
    "        test_ds = test_ds.map(tokenize_fn, batched=True)\n",
    "\n",
    "        data_collator = DataCollatorWithPadding(tokenizer=bert_tokenizer)\n",
    "        bert_model = DistilBertForSequenceClassification.from_pretrained(\n",
    "            TRANSFORMER_MODEL_NAME, num_labels=NUM_CLASSES)\n",
    "\n",
    "        def compute_metrics(eval_pred):\n",
    "            logits, labels = eval_pred\n",
    "            preds = np.argmax(logits, axis=1)\n",
    "            return {\"accuracy\": accuracy_score(labels, preds),\n",
    "                    \"macro_f1\": f1_score(labels, preds, average=\"macro\")}\n",
    "\n",
    "        training_args = TrainingArguments(\n",
    "            output_dir=\"./distilbert_emotion\",\n",
    "            eval_strategy=\"epoch\",\n",
    "            save_strategy=\"epoch\",\n",
    "            learning_rate=2e-5,\n",
    "            per_device_train_batch_size=32,\n",
    "            per_device_eval_batch_size=64,\n",
    "            num_train_epochs=TRANSFORMER_EPOCHS,\n",
    "            weight_decay=0.01,\n",
    "            load_best_model_at_end=True,\n",
    "            metric_for_best_model=\"macro_f1\",\n",
    "            logging_steps=100,\n",
    "            report_to=\"none\",\n",
    "        )\n",
    "\n",
    "        trainer = Trainer(\n",
    "            model=bert_model, args=training_args,\n",
    "            train_dataset=train_ds, eval_dataset=val_ds,\n",
    "            tokenizer=bert_tokenizer, data_collator=data_collator,\n",
    "            compute_metrics=compute_metrics,\n",
    "        )\n",
    "\n",
    "        trainer.train()\n",
    "\n",
    "        test_pred = trainer.predict(test_ds)\n",
    "        y_pred_bert = np.argmax(test_pred.predictions, axis=1)\n",
    "        y_true_bert = np.array(test_ds[\"label\"])\n",
    "\n",
    "        _ = evaluate_model(\"DistilBERT (fine-tuned)\", y_true_bert, y_pred_bert, le.classes_)\n",
    "\n",
    "        os.makedirs(\"models/distilbert_emotion\", exist_ok=True)\n",
    "        trainer.save_model(\"models/distilbert_emotion\")\n",
    "        bert_tokenizer.save_pretrained(\"models/distilbert_emotion\")\n",
    "        print(\"Saved fine-tuned DistilBERT to models/distilbert_emotion/\")\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"[Skipping DistilBERT fine-tuning here] {type(e).__name__}: {e}\")\n",
    "        print(\"This cell is fully functional in an environment with internet access to huggingface.co\")\n",
    "        print(\"(e.g. Google Colab, Kaggle, or a local machine with a GPU). Re-run it there for real results.\")\n",
    "else:\n",
    "    print(\"RUN_TRANSFORMER is False — skipping DistilBERT fine-tuning.\")\n"
   ]
  },
